		"devdoc": {
			"kind": "dev",
			"methods": {
				"registerBounty(uint256,uint256)": {
					"params": {
						"bountyId": "The bounty identifier from AIJudge.",
						"deadline": "block.timestamp deadline copied from AIJudge.Bounty.deadline."
					}
				},
				"revealAnswer(uint256,string,bytes32)": {
					"params": {
						"answer": "Plaintext answer string committed earlier.",
						"bountyId": "Target bounty.",
						"salt": "Random salt used when building the commitment. Valid window: (deadline, deadline + REVEAL_WINDOW]"
					}
				},
				"submitCommitment(uint256,bytes32)": {
					"params": {
						"bountyId": "Target bounty.",
						"commitment": "keccak256(abi.encodePacked(answer, salt, msg.sender, bountyId))"
					}
				}
			},
			"title": "CommitReveal",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"MAX_ANSWER_LENGTH()": {
					"notice": "Maximum answer length (mirrors AIJudge.MAX_ANSWER_LENGTH)."
				},
				"REVEAL_WINDOW()": {
					"notice": "How long after the commit deadline the reveal window stays open."
				},
				"bountyMeta(uint256)": {
					"notice": "bountyId => BountyMeta"
				},
				"currentPhase(uint256)": {
					"notice": "Current phase for a bounty.         0 = commit open, 1 = reveal open, 2 = closed / not registered."
				},
				"entries(uint256,address)": {
					"notice": "bountyId => submitter => Entry"
				},
				"getAnswer(uint256,address)": {
					"notice": "Returns the revealed answer for a participant.         Reverts if not yet revealed — AIJudge should call this to gate judging."
				},
				"hasRevealed(uint256,address)": {
					"notice": "True only if the participant committed AND successfully revealed."
				},
				"makeCommitment(string,bytes32,address,uint256)": {
					"notice": "Compute the commitment hash (use off-chain or in tests)."
				},
				"registerBounty(uint256,uint256)": {
					"notice": "Register a bounty's deadline so this contract can enforce phases.         Called by the bounty owner (or AIJudge itself) after createBounty."
				},
				"revealAnswer(uint256,string,bytes32)": {
					"notice": "Reveal the answer after the submission deadline."
				},
				"submitCommitment(uint256,bytes32)": {
					"notice": "Submit a commitment for a specific bounty."
				}
			},
			"notice": "Commit-reveal scheme scoped per bounty, compatible with AIJudge. Commitment formula:   keccak256(abi.encodePacked(answer, salt, msg.sender, bountyId)) Flow:   1. commit(bountyId, hash)        — before bounty deadline   2. reveal(bountyId, answer, salt) — after deadline, within reveal window   3. AIJudge.judgeAll only considers entries where revealed == true",
			"version": 1
		}
